{
  "expo": {
    "name": "FAMO Rider",
    "slug": "famo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "famo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.famo.rider",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyArKLk-HgW6rzHvL30UG70sux3FjepcSSI"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "FAMO needs access to your camera so you can take photos of your documents.",
          "photosPermission": "FAMO needs access to your photos so you can upload your documents.",
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f8f9ff",
          "image": "./assets/images/FAMO-logo-dark.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#f8f9ff",
            "image": "./assets/images/FAMO-logo-dark.png"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-foreground.png",
          "color": "#fbd103",
          "defaultChannel": "delivery-offers"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8819559f-5d56-4c93-b634-8fc4c1451963"
      }
    },
    "owner": "zaryabb"
  }
}
